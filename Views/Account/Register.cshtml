@model HealthSpark.ViewModels.RegisterViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register — HealthSpark</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="auth-body">

    <div class="auth-wrapper">

        <div class="auth-brand">
            <div class="auth-brand-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                </svg>
            </div>
            <div class="auth-brand-name">HealthSpark</div>
        </div>

        <div class="auth-card">
            <div class="auth-card-header">
                <div class="auth-title">Create your account</div>
                <div class="auth-sub">Join HealthSpark to start monitoring your health</div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="auth-error">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                        <line x1="12" y1="9" x2="12" y2="13" />
                        <line x1="12" y1="17" x2="12.01" y2="17" />
                    </svg>
                    @Model.ErrorMessage
                </div>
            }

            <form asp-action="Register" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()

                <div class="form-grid-2">
                    <div class="form-group">
                        <label asp-for="FullName" class="form-label">Full Name</label>
                        <input asp-for="FullName"
                               class="form-input"
                               placeholder="John Obi" />
                        <span asp-validation-for="FullName" class="field-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                        <input asp-for="PhoneNumber"
                               class="form-input"
                               placeholder="+44 7700 900000" />
                        <span asp-validation-for="PhoneNumber" class="field-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email"
                           class="form-input"
                           placeholder="you@example.com"
                           autocomplete="email" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="form-grid-2">
                    <div class="form-group">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password"
                               class="form-input"
                               placeholder="Min. 6 characters"
                               autocomplete="new-password" />
                        <span asp-validation-for="Password" class="field-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                        <input asp-for="ConfirmPassword"
                               class="form-input"
                               placeholder="Repeat password"
                               autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                    </div>
                </div>

                <div class="form-grid-2">
                    <div class="form-group">
                        <label asp-for="DateOfBirth" class="form-label">Date of Birth</label>
                        <input asp-for="DateOfBirth"
                               class="form-input"
                               type="date" />
                        <span asp-validation-for="DateOfBirth" class="field-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Gender" class="form-label">Gender</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">Select gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="field-error"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-full">
                    Create Account
                </button>

            </form>

            <div class="auth-footer">
                Already have an account?
                <a href="@Url.Action("Login", "Account")">Sign in</a>
            </div>

        </div>

    </div>

</body>
</html>