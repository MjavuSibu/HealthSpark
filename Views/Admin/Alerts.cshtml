@model HealthSpark.ViewModels.DashboardViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "System Alerts";
    ViewData["ActivePage"] = "Alerts";
    ViewData["Sidebar"] = "_AdminSidebar";
}

<!-- Alerts Summary -->
<div class="stats-grid" style="grid-template-columns: repeat(3, 1fr); margin-bottom:24px;">
    <div class="stat-card">
        <div class="stat-icon-wrap si-red">
            <svg width="18" height="18"><use href="#ic-alert" /></svg>
        </div>
        <div class="stat-value">@Model.Alerts.Count</div>
        <div class="stat-label">Unresolved Alerts</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon-wrap si-purple">
            <svg width="18" height="18"><use href="#ic-heart-pulse" /></svg>
        </div>
        <div class="stat-value">
            @Model.Alerts.Count(a => a.CreatedAt.Date == DateTime.UtcNow.Date)
        </div>
        <div class="stat-label">New Today</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon-wrap si-green">
            <svg width="18" height="18"><use href="#ic-check-circle" /></svg>
        </div>
        <div class="stat-value">0</div>
        <div class="stat-label">Resolved Today</div>
    </div>
</div>

<!-- Alerts List -->
<div class="card">
    <div class="card-header">
        <div class="card-title">All Active Alerts</div>
        <span class="badge badge-inactive">
            @Model.Alerts.Count Unresolved
        </span>
    </div>
    <div class="card-body">
        @if (!Model.Alerts.Any())
        {
            <div class="empty-state">
                <svg width="32" height="32" style="color:var(--text-soft);margin-bottom:10px;">
                    <use href="#ic-check-circle" />
                </svg>
                <div>No active alerts. Everything looks good.</div>
            </div>
        }
        else
        {
            @foreach (var alert in Model.Alerts)
            {
                <div class="alert-row">
                    <div class="alert-icon">
                        <svg width="16" height="16"><use href="#ic-alert" /></svg>
                    </div>
                    <div class="alert-body">
                        <div class="alert-name">@alert.Message</div>
                        <div class="alert-desc">
                            Patient ID: @alert.PatientId ·
                            @alert.CreatedAt.ToString("dd MMM yyyy · HH:mm")
                        </div>
                    </div>
                    <div style="text-align:right; flex-shrink:0;">
                        <div style="font-size:11px;color:var(--text-soft);margin-bottom:7px;">
                            @{
                                var timeAgo = DateTime.UtcNow - alert.CreatedAt;
                                var timeAgoText = timeAgo.TotalMinutes < 60
                                ? $"{(int)timeAgo.TotalMinutes} mins ago"
                                : timeAgo.TotalHours < 24
                                ? $"{(int)timeAgo.TotalHours} hrs ago"
                                : $"{(int)timeAgo.TotalDays} days ago";
                            }
                            @timeAgoText
                        </div>
                        <form asp-action="ResolveAlert"
                              asp-controller="Admin"
                              method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="alertId" value="@alert.Id" />
                            <button type="submit" class="btn btn-ghost btn-sm">
                                Resolve
                            </button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>