@model HealthSpark.ViewModels.DashboardViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    ViewData["Sidebar"] = "_AdminSidebar";
}

<!-- Welcome Banner -->
<div class="welcome-banner">
    <div class="welcome-title">Good morning, @ViewData["CurrentUserName"]</div>
    <div class="welcome-sub">Here's what's happening in the system today.</div>
    <div class="welcome-date">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</div>
</div>

<!-- Stat Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon-wrap si-purple">
            <svg width="18" height="18"><use href="#ic-stethoscope" /></svg>
        </div>
        <div class="stat-value">@Model.TotalDoctors</div>
        <div class="stat-label">Total Doctors</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon-wrap si-lilac">
            <svg width="18" height="18"><use href="#ic-users" /></svg>
        </div>
        <div class="stat-value">@Model.TotalPatients</div>
        <div class="stat-label">Total Patients</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon-wrap si-green">
            <svg width="18" height="18"><use href="#ic-calendar" /></svg>
        </div>
        <div class="stat-value">@Model.TotalAppointmentsToday</div>
        <div class="stat-label">Appointments Today</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon-wrap si-red">
            <svg width="18" height="18"><use href="#ic-alert" /></svg>
        </div>
        <div class="stat-value">@Model.TotalFlaggedReadings</div>
        <div class="stat-label">Flagged Readings</div>
    </div>
</div>

<!-- Unassigned Patients & Flagged Alerts -->
<div class="grid-2">
    <div class="card">
        <div class="card-header">
            <div class="card-title">Unassigned Patients</div>
            <span class="badge badge-pending">
                @Model.UnassignedPatients.Count Pending
            </span>
        </div>
        <div class="card-body">
            @if (!Model.UnassignedPatients.Any())
            {
                <div class="empty-state">All patients are assigned.</div>
            }
            else
            {
                @foreach (var patient in Model.UnassignedPatients)
                {
                    <div class="activity-item">
                        <div class="avatar av-1">
                            @patient.FullName[..2].ToUpper()
                        </div>
                        <div style="flex:1;">
                            <div class="user-name">@patient.FullName</div>
                            <div class="user-email">@patient.Email</div>
                        </div>
                        <a href="@Url.Action("Assignments", "Admin")"
                           class="btn btn-primary btn-sm">
                            Assign
                        </a>
                    </div>
                }
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">System Alerts</div>
            <span class="badge badge-inactive">
                @Model.Alerts.Count Active
            </span>
        </div>
        <div class="card-body">
            @if (!Model.Alerts.Any())
            {
                <div class="empty-state">No active alerts.</div>
            }
            else
            {
                @foreach (var alert in Model.Alerts.Take(3))
                {
                    <div class="alert-row">
                        <div class="alert-icon">
                            <svg width="16" height="16"><use href="#ic-alert" /></svg>
                        </div>
                        <div class="alert-body">
                            <div class="alert-name">@alert.Message</div>
                            <div class="alert-desc">
                                @alert.CreatedAt.ToString("dd MMM yyyy · HH:mm")
                            </div>
                        </div>
                        <form asp-action="ResolveAlert" asp-controller="Admin"
                              method="post" style="flex-shrink:0;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="alertId" value="@alert.Id" />
                            <button type="submit" class="btn btn-ghost btn-sm">
                                Resolve
                            </button>
                        </form>
                    </div>
                }
            }
        </div>
    </div>
</div>

<!-- Recent Doctors & Patients -->
<div class="grid-2">
    <div class="card">
        <div class="card-header">
            <div class="card-title">Doctors</div>
            <a href="@Url.Action("Doctors", "Admin")"
               class="btn btn-ghost btn-sm">View All</a>
        </div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Doctor</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doctor in Model.AllDoctors.Take(5))
                    {
                        <tr>
                            <td>
                                <div class="user-cell">
                                    <div class="avatar av-1">
                                        @doctor.FullName[..2].ToUpper()
                                    </div>
                                    <div>
                                        <div class="user-name">@doctor.FullName</div>
                                        <div class="user-email">@doctor.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge @(doctor.IsActive ? "badge-active" : "badge-inactive")">
                                    @(doctor.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">Recent Patients</div>
            <a href="@Url.Action("Patients", "Admin")"
               class="btn btn-ghost btn-sm">View All</a>
        </div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var patient in Model.AllPatients.Take(5))
                    {
                        <tr>
                            <td>
                                <div class="user-cell">
                                    <div class="avatar av-2">
                                        @patient.FullName[..2].ToUpper()
                                    </div>
                                    <div>
                                        <div class="user-name">@patient.FullName</div>
                                        <div class="user-email">@patient.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge @(patient.IsActive ? "badge-active" : "badge-inactive")">
                                    @(patient.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>