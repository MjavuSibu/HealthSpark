@model HealthSpark.ViewModels.DashboardViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    ViewData["Sidebar"] = "_PatientSidebar";
    ViewData["CurrentUserName"] = Model.CurrentUser.FullName;
    ViewData["AlertCount"] = Model.Alerts.Count;
}

<!-- Welcome Banner -->
<div class="welcome-banner">
    <div class="welcome-title">
        Good morning, @Model.CurrentUser.FullName
    </div>
    <div class="welcome-sub">
        @if (Model.UpcomingAppointments.Any())
        {
            var next = Model.UpcomingAppointments.First();
            <span>
                You have an appointment on @next.Date at @next.TimeSlot.
                Don't forget to log your vitals.
            </span>
        }
        else
        {
            <span>Welcome back. Remember to log your vitals today.</span>
        }
    </div>
    <div class="welcome-date">
        @DateTime.Now.ToString("dddd, dd MMMM yyyy")
    </div>
</div>

<!-- Quick Actions -->
<div class="quick-actions">
    <div class="quick-card" onclick="openModal('logVitalsModal')">
        <div class="quick-icon qi-purple">
            <svg width="18" height="18"><use href="#ic-heart-pulse" /></svg>
        </div>
        <div class="quick-title">Log Vitals</div>
        <div class="quick-sub">
            @if (Model.LatestVital != null)
            {
                <span>Last: @Model.LatestVital.LoggedAt.ToString("dd MMM")</span>
            }
            else
            {
                <span>Not logged yet</span>
            }
        </div>
    </div>
    <div class="quick-card"
         onclick="window.location='@Url.Action("Symptoms", "Patient")'">
        <div class="quick-icon qi-red">
            <svg width="18" height="18"><use href="#ic-clipboard" /></svg>
        </div>
        <div class="quick-title">Log Symptom</div>
        <div class="quick-sub">Get AI assessment</div>
    </div>
    <div class="quick-card" onclick="openModal('bookApptModal')">
        <div class="quick-icon qi-green">
            <svg width="18" height="18"><use href="#ic-calendar" /></svg>
        </div>
        <div class="quick-title">Book Appointment</div>
        <div class="quick-sub">
            @if (Model.UpcomingAppointments.Any())
            {
                <span>Next: @Model.UpcomingAppointments.First().Date</span>
            }
            else
            {
                <span>No upcoming appointments</span>
            }
        </div>
    </div>
    <div class="quick-card"
         onclick="window.location='@Url.Action("DoctorNotes", "Patient")'">
        <div class="quick-icon qi-lilac">
            <svg width="18" height="18"><use href="#ic-stethoscope" /></svg>
        </div>
        <div class="quick-title">My Doctor</div>
        <div class="quick-sub">View notes & info</div>
    </div>
</div>

<div class="grid-3">
    <div>
        <!-- Latest Vitals -->
        @if (Model.LatestVital != null)
        {
            <div class="vitals-grid" style="margin-bottom:18px;">
                <div class="vital-card">
                    <div class="vital-label">Blood Pressure</div>
                    <div class="vital-value" style="font-size:20px;">
                        @Model.LatestVital.BloodPressureSystolic /
                        @Model.LatestVital.BloodPressureDiastolic
                    </div>
                    <div class="vital-unit">mmHg</div>
                    @if (Model.LatestVital.BloodPressureSystolic > 140)
                    {
                        <div class="vital-flag">
                            <svg width="11" height="11"><use href="#ic-alert" /></svg> High
                        </div>
                    }
                    else
                    {
                        <div class="vital-ok">
                            <svg width="11" height="11"><use href="#ic-check-circle" /></svg> Normal
                        </div>
                    }
                </div>
                <div class="vital-card">
                    <div class="vital-label">Heart Rate</div>
                    <div class="vital-value">@Model.LatestVital.HeartRate</div>
                    <div class="vital-unit">bpm</div>
                    @if (Model.LatestVital.HeartRate > 100 || Model.LatestVital.HeartRate < 60)
                    {
                        <div class="vital-flag">
                            <svg width="11" height="11"><use href="#ic-alert" /></svg> Abnormal
                        </div>
                    }
                    else
                    {
                        <div class="vital-ok">
                            <svg width="11" height="11"><use href="#ic-check-circle" /></svg> Normal
                        </div>
                    }
                </div>
                <div class="vital-card">
                    <div class="vital-label">Blood Glucose</div>
                    <div class="vital-value">@Model.LatestVital.BloodGlucose</div>
                    <div class="vital-unit">mmol/L</div>
                    @if (Model.LatestVital.BloodGlucose > 11)
                    {
                        <div class="vital-flag">
                            <svg width="11" height="11"><use href="#ic-alert" /></svg> High
                        </div>
                    }
                    else
                    {
                        <div class="vital-ok">
                            <svg width="11" height="11"><use href="#ic-check-circle" /></svg> Normal
                        </div>
                    }
                </div>
                <div class="vital-card">
                    <div class="vital-label">Sleep</div>
                    <div class="vital-value">@Model.LatestVital.SleepHours</div>
                    <div class="vital-unit">hours</div>
                    @if (Model.LatestVital.SleepHours < 7)
                    {
                        <div class="vital-flag">
                            <svg width="11" height="11"><use href="#ic-alert" /></svg> Below target
                        </div>
                    }
                    else
                    {
                        <div class="vital-ok">
                            <svg width="11" height="11"><use href="#ic-check-circle" /></svg> Good
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Upcoming Appointments -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">Upcoming Appointments</div>
                <a href="@Url.Action("Appointments", "Patient")"
                   class="btn btn-ghost btn-sm">View All</a>
            </div>
            <div class="card-body">
                @if (!Model.UpcomingAppointments.Any())
                {
                    <div class="empty-state">No upcoming appointments.</div>
                }
                else
                {
                    @foreach (var appt in Model.UpcomingAppointments.Take(3))
                    {
                        <div class="appt-item">
                            <div class="appt-date-block">
                                <div class="appt-day">
                                    @appt.Date.Split(' ')[0]
                                </div>
                                <div class="appt-month">
                                    @(appt.Date.Split(' ').Length > 1 ? appt.Date.Split(' ')[1] : "")
                                </div>
                            </div>
                            <div class="appt-divider"></div>
                            <div class="appt-info">
                                <div class="appt-title">@appt.Reason</div>
                                <div class="appt-doctor">Dr. · @appt.TimeSlot</div>
                            </div>
                            <span class="badge @(appt.Status == "confirmed"
                                                  ? "badge-active" : "badge-pending")">
                        @appt.Status
                    </span>
                </div>
                                }
                }
            </div>
        </div>
    </div>

    <!-- Right Column -->
    <div style="display:flex;flex-direction:column;gap:18px;">

        <!-- Latest Notification -->
        @if (Model.Alerts.Any())
        {
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Latest Alert</div>
                </div>
                <div class="card-body">
                    <div style="display:flex;gap:10px;align-items:flex-start;">
                        <div style="width:34px;height:34px;background:rgba(232,128,154,0.12);
                            border-radius:9px;display:flex;align-items:center;
                            justify-content:center;flex-shrink:0;color:var(--danger);">
                            <svg width="16" height="16"><use href="#ic-alert" /></svg>
                        </div>
                        <div>
                            <div style="font-size:13px;font-weight:600;color:var(--text-dark);">
                                @Model.Alerts.First().Message
                            </div>
                            <div style="font-size:11px;color:var(--text-soft);margin-top:7px;">
                                @{
                                    var timeAgo = DateTime.UtcNow - Model.Alerts.First().CreatedAt;
                                    @(timeAgo.TotalHours < 1
                                                                ? $"{(int)timeAgo.TotalMinutes} mins ago"
                                                                : timeAgo.TotalHours < 24
                                                                ? $"{(int)timeAgo.TotalHours} hrs ago"
                                                                : $"{(int)timeAgo.TotalDays} days ago")
                                                        }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Latest Doctor Note -->
        @if (Model.LatestDoctorNote != null)
        {
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Doctor's Latest Note</div>
                </div>
                <div class="card-body">
                    <div style="font-size:13px;color:var(--text-mid);line-height:1.6;">
                        @Model.LatestDoctorNote.Note
                    </div>
                    <div style="font-size:11px;color:var(--text-soft);margin-top:10px;">
                        @Model.LatestDoctorNote.CreatedAt.ToString("dd MMM yyyy · HH:mm")
                    </div>
                </div>
            </div>
        }

    </div>
</div>

<!-- Log Vitals Modal -->
<div class="modal-overlay" id="logVitalsModal">
    <div class="modal">
        <div class="modal-title">Log Vitals</div>
        <div class="modal-sub">
            All fields are optional — log what you have available.
        </div>
        <form asp-action="LogVitals" asp-controller="Patient" method="post">
            @Html.AntiForgeryToken()
            <div class="vitals-form-grid">
                <div class="form-group">
                    <label class="form-label">Systolic BP</label>
                    <div class="input-with-unit">
                        <input name="BloodPressureSystolic" class="form-input"
                               type="number" placeholder="e.g. 120" />
                        <span class="input-unit">mmHg</span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Diastolic BP</label>
                    <div class="input-with-unit">
                        <input name="BloodPressureDiastolic" class="form-input"
                               type="number" placeholder="e.g. 80" />
                        <span class="input-unit">mmHg</span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Heart Rate</label>
                    <div class="input-with-unit">
                        <input name="HeartRate" class="form-input"
                               type="number" placeholder="e.g. 72" />
                        <span class="input-unit">bpm</span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Blood Glucose</label>
                    <div class="input-with-unit">
                        <input name="BloodGlucose" class="form-input"
                               type="number" step="0.1" placeholder="e.g. 7.2" />
                        <span class="input-unit">mmol/L</span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Temperature</label>
                    <div class="input-with-unit">
                        <input name="Temperature" class="form-input"
                               type="number" step="0.1" placeholder="e.g. 37.0" />
                        <span class="input-unit">°C</span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Weight</label>
                    <div class="input-with-unit">
                        <input name="Weight" class="form-input"
                               type="number" step="0.1" placeholder="e.g. 80" />
                        <span class="input-unit">kg</span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Sleep Last Night</label>
                    <div class="input-with-unit">
                        <input name="SleepHours" class="form-input"
                               type="number" step="0.5" placeholder="e.g. 7.5" />
                        <span class="input-unit">hrs</span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Water Intake</label>
                    <div class="input-with-unit">
                        <input name="WaterIntakeLitres" class="form-input"
                               type="number" step="0.1" placeholder="e.g. 2.0" />
                        <span class="input-unit">L</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost"
                        onclick="closeModal('logVitalsModal')">
                    Cancel
                </button>
                <button type="submit" class="btn btn-primary">Save Vitals</button>
            </div>
        </form>
    </div>
</div>

<!-- Book Appointment Modal -->
<div class="modal-overlay" id="bookApptModal">
    <div class="modal">
        <div class="modal-title">Book Appointment</div>
        <div class="modal-sub">Request an appointment with your doctor.</div>
        <form asp-action="BookAppointment" asp-controller="Patient" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Preferred Date</label>
                <input name="Date" class="form-input" type="date" />
            </div>
            <div class="form-group">
                <label class="form-label">Preferred Time</label>
                <select name="TimeSlot" class="form-select">
                    <option value="09:00 AM">09:00 AM</option>
                    <option value="10:00 AM">10:00 AM</option>
                    <option value="11:00 AM">11:00 AM</option>
                    <option value="12:00 PM">12:00 PM</option>
                    <option value="02:00 PM">02:00 PM</option>
                    <option value="03:00 PM">03:00 PM</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Reason for Appointment</label>
                <textarea name="Reason" class="form-textarea"
                          style="min-height:70px;"
                          placeholder="Briefly describe why you'd like to book...">
        </textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost"
                        onclick="closeModal('bookApptModal')">
                    Cancel
                </button>
                <button type="submit" class="btn btn-primary">
                    Request Appointment
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openModal(id)  { document.getElementById(id).classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }

        document.querySelectorAll('.modal-overlay').forEach(o => {
          o.addEventListener('click', e => {
            if (e.target === o) o.classList.remove('open');
          });
        });
    </script>
}